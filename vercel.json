{
  "rewrites": [
    { "source": "/api/cboe/:path*",   "destination": "https://cdn.cboe.com/:path*" },
    { "source": "/api/reddit/:path*", "destination": "https://www.reddit.com/:path*" },
    { "source": "/((?!api/).*)",      "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://engine.rainmarket.com"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://engine.rainmarket.com"
        }
      ]
    }
  ]
}
